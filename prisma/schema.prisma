// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Word {
  id          String   @id @default(cuid())
  rootWord    String   // Akar kata (contoh: كتب, اكرم)
  indonesian  String   // Arti bahasa Indonesia (opsional di awal)
  bab         String?  // Bab fi'il (contoh: Bab 1, Asalnya Af'ala)
  bina        String?  // Jenis bina' terperinci (contoh: Shohih Salim, Shohih Mahmuz Fa', dll)
  transitive  String?  // Lazim / Muta'addi / Keduanya
  jenisFiil   String?  // Tsulatsi Mujarrod / Tsulatsi Mazid / Ruba'i Mujarrod / Ruba'i Mazid
  
  // Tasrif Istilahi
  madhi       String
  mudhari     String
  masdar      String
  masdarMim   String?
  faail       String
  mafuul      String?
  amr         String
  nahyi       String
  zamanMakan  String
  alaat       String?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([madhi, bab])
}
